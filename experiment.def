Bootstrap: docker
From: nvcr.io/nvidia/pytorch:24.07-py3

%labels
    Description CER experiment container

%post
    apt-get update && apt-get install -y --no-install-recommends \
        git \
        vim \
        less \
        && rm -rf /var/lib/apt/lists/*

    pip install --no-cache-dir \
        wandb \
        pyyaml \
        scipy \
        matplotlib \
        tqdm \
        anthropic \
        pytorch-lightning \
        hydra-core \
        omegaconf \
        mcp

%environment
    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8

%runscript
    exec python "$@"
